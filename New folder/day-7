// 2.1 -- Default Constructor

class wifiConnection {
public:    
    string networkName;
    string password;
    
    // Constructor
    wifiConnection() {
        networkName = "ACTFibre";
        password = "BJP wons";
    }
    
public:
void showDetails() {
   cout << "NetWork name is " << networkName << " and its password is " << password; 
    }
};

int main() {
    wifiConnection obj1;
    obj1.showDetails();
}
// 2.2 -- Parameterized Constructor: Pass data at creation
class Student {
public:
    string name;
    int id;

    Student(string studentName, int studentID){
        name = studentName;
        id = studentID;
    }

    void displayDetails() { cout << "Student: " << name << " (ID: " << id << ")\n"; }    
};

// ==============================================
// 💎 PROBLEM 03: ENCAPSULATION 💊
// 📝 Task: Data hiding and Controlled Access (Getters/Setters)
// 🖼️ Concept: Binding variables & methods into one unit
// ==============================================

class bankAccount {
private:
    int balance;    

public:   
    void setBalance(int amount) {
        if(amount >= 0) {
            balance = amount;
        } else {
            cout << "Error: Invalid Amount!\n";
        }
    }
    
    int getbalance() { return balance; }
};

// ==============================================
// 💎 PROBLEM 04: ABSTRACTION 🌫️
// 📝 Task: Hiding implementation, showing only essentials
// ==============================================

/* 
 * Abstract Class: A blueprint that cannot be instantiated.
 * Abstract Method: A method declared without an implementation (Pure Virtual).
 */

int main() {
    cout << "--- Access Specifier Demo ---\n";
    child obj1;
    obj1.accessOfSecretCode();

    cout << "\n--- Constructor Demo ---\n";
    wifiConnection wifi;
    wifi.showDetails();
    
    Student std1("Abhishek", 101); // Abhishek Aggarwal, Age 24
    std1.displayDetails();

    cout << "\n--- Encapsulation Demo ---\n";
    bankAccount myAcc;
    myAcc.setBalance(6000);
    cout << "Verified Balance: " << myAcc.getbalance() << "\n";

    return 0;
}

