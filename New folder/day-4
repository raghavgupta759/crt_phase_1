// Problem 5 
// Print a Rectangle

#include <iostream>
using namespace std;

int main() {
    int row, col;
    cin >> row;
    cin >> col;
    
    for(int i = 1; i <= row; i++) {
        for(int j = 1; j <= col; j++) {
            cout <<"*";
        }
        cout <<"\n";
    }
}
